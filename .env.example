# Plantilla de variables de entorno.
# Copia este archivo a `.env` y rellena con tus credenciales reales.
# El archivo `.env` NUNCA debe subirse a git.

# Facebook Marketing API
FB_ACCESS_TOKEN=
FB_APP_ID=
FB_APP_SECRET=

# Cuentas publicitarias (OPCIONAL — filtro).
#   Vacío  → se usan TODAS las cuentas a las que el token tiene acceso
#            (descubiertas vía /me/adaccounts).
#   Lista  → solo se procesan esas (IDs separados por coma).
# Ejemplo: FB_AD_ACCOUNT_ID=act_XXXXXXXXX,act_YYYYYYYYY
FB_AD_ACCOUNT_ID=

# Tasas de cambio hacia COP. Define una variable por cada moneda que tengan
# tus cuentas (formato: <MONEDA>_TO_COP). Las cuentas que ya estén en COP no
# se convierten. Si una cuenta usa una moneda sin tasa configurada, su gasto
# se queda en la moneda original y verás un aviso por stderr.
USD_TO_COP=4000
MXN_TO_COP=200

# Supabase (solo lectura)
SUPABASE_URL=
SUPABASE_KEY=

# Nombre de la tabla de ventas en Supabase
SALES_TABLE=compradores
# Nombre de la tabla de contactos (origen real de las conversaciones de WhatsApp)
CONTACTS_TABLE=contactos

# ─── Asistente de IA (OpenAI) ────────────────────────────────────────────────
# API key de OpenAI. Si la dejas vacía, el chat aparece deshabilitado.
OPENAI_API_KEY=

# Nota: los parámetros del NEGOCIO (margen, umbrales de CPA y ROAS, meta de
# ganancia diaria) ya NO viven aquí. Se gestionan desde el panel
# "⚙️ Configuración del negocio" en la barra lateral del dashboard, y se
# guardan en `config.json` en la raíz del proyecto. Si tenías valores antiguos
# definidos aquí (MARGEN_PORCENTAJE, CPA_BUENO, CPA_MAXIMO, ROAS_MINIMO,
# ROAS_BUENO), el primer arranque los migra automáticamente a `config.json`.
