# Plantilla de variables de entorno.
# Copia este archivo a `.env` y rellena con tus credenciales reales.
# El archivo `.env` NUNCA debe subirse a git.

# Facebook Marketing API
FB_ACCESS_TOKEN=
# Una o varias cuentas publicitarias separadas por coma (sin espacios obligatorios).
FB_AD_ACCOUNT_ID=act_XXXXXXXXX,act_YYYYYYYYY
FB_APP_ID=
FB_APP_SECRET=

# Tasa de cambio USD → COP. Solo se aplica al gasto de las cuentas que NO estén en COP.
# Si se deja vacía o no se define, el código usa 4000 por defecto.
USD_TO_COP=4000

# Supabase (solo lectura)
SUPABASE_URL=
SUPABASE_KEY=

# Nombre de la tabla de ventas en Supabase
SALES_TABLE=compradores
